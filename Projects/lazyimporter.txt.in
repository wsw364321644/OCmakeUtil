cmake_minimum_required(VERSION 3.23)
include(FetchContent)
set(FETCHCONTENT_QUIET FALSE)

set(IMPORT_PROJECT_STATIC_CRT @IMPORT_PROJECT_STATIC_CRT@)
set(OCMAKEUTIL_PATH @OCMAKEUTIL_PATH@)
set(OCMAKEUTIL_PROJECTS_PATH @OCMAKEUTIL_PROJECTS_PATH@)
set(ProjectName_Lower @ProjectName_Lower@)
set(ProjectName @ProjectName@)

project(${ProjectName})
include(GNUInstallDirs)

add_subdirectory(${OCMAKEUTIL_PATH} ${CMAKE_CURRENT_BINARY_DIR}/ocmakeutil)

if(CMAKE_INSTALL_PREFIX_INITIALIZED_TO_DEFAULT)
    set(CMAKE_INSTALL_PREFIX
        "${CMAKE_BINARY_DIR}/${ProjectName_Lower}-prefix"
        CACHE STRING "Directory to install after building" FORCE)
endif()

FetchContent_Declare(download_${ProjectName_Lower}
  GIT_REPOSITORY @GIT_REPOSITORY@
  GIT_TAG @IMPORT_PROJECT_TAG@
  SOURCE_SUBDIR "avoid_add_subdirectory"
)


FetchContent_MakeAvailable(download_${ProjectName_Lower})
FetchContent_GetProperties(download_${ProjectName_Lower}
    SOURCE_DIR download_${ProjectName_Lower}_SOURCE_DIR
)

NewTargetSource()
AddSourceFolder(INCLUDE RECURSE INTERFACE "${download_${ProjectName_Lower}_SOURCE_DIR}/include")

set(TARGET_NAME lazy_importer)
add_library(${TARGET_NAME} INTERFACE)
add_library(${PROJECT_NAME}::${TARGET_NAME} ALIAS ${TARGET_NAME})
AddTargetInclude(${TARGET_NAME})
AddTargetInstall(${TARGET_NAME} ${PROJECT_NAME})

ExportFromInstall(${PROJECT_NAME})
