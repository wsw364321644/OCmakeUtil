cmake_minimum_required(VERSION 3.24)
include(FetchContent)
set(OCMAKEUTIL_PATH @OCMAKEUTIL_PATH@)
set(OCMAKEUTIL_PROJECTS_PATH @OCMAKEUTIL_PROJECTS_PATH@)
set(CMAKE_PREFIX_PATH @CMAKE_PREFIX_PATH@)
set(CMAKE_MODULE_PATH @CMAKE_MODULE_PATH@)
set(IMPORT_PROJECT_STATIC_CRT @IMPORT_PROJECT_STATIC_CRT@)
set(ProjectName_Lower @ProjectName_Lower@)
set(ProjectName @ProjectName@)

project(${ProjectName})
enable_language(CXX)
include(GNUInstallDirs)

add_subdirectory(${OCMAKEUTIL_PATH} "${CMAKE_CURRENT_BINARY_DIR}/ocmakeutil-build")

if(CMAKE_INSTALL_PREFIX_INITIALIZED_TO_DEFAULT)
  set(CMAKE_INSTALL_PREFIX
    "${CMAKE_BINARY_DIR}/${PROJECT_NAME}-prefix"
    CACHE STRING "Directory to install after building" FORCE)
endif()

if(IMPORT_PROJECT_STATIC_CRT)
  set(CMAKE_MSVC_RUNTIME_LIBRARY "MultiThreaded$<$<CONFIG:Debug>:Debug>")
else()
  set(CMAKE_MSVC_RUNTIME_LIBRARY "MultiThreaded$<$<CONFIG:Debug>:Debug>DLL")
endif()

FetchContent_Declare(
  ${PROJECT_NAME}
  GIT_REPOSITORY @GIT_REPOSITORY@
  GIT_TAG @IMPORT_PROJECT_TAG@
  GIT_SHALLOW @GIT_SHALLOW_VAL@
)
FetchContent_MakeAvailable(${PROJECT_NAME})
FetchContent_GetProperties(${PROJECT_NAME})

NewTargetSource()
AddSourceFolder(PUBLIC "${${PROJECT_NAME}_SOURCE_DIR}")

function(add_inih TARGET_NAME)
  AddTargetInclude(${TARGET_NAME})
  AddTargetInstall(${TARGET_NAME} ${PROJECT_NAME})
endfunction()

set(TARGET_NAME inih)
add_library(${TARGET_NAME} SHARED)
add_library(${PROJECT_NAME}::${TARGET_NAME} ALIAS ${TARGET_NAME})
target_compile_definitions(${TARGET_NAME} PUBLIC -DINI_SHARED_LIB)
target_compile_definitions(${TARGET_NAME} PRIVATE -DINI_SHARED_LIB_BUILDING)
set_target_properties(${TARGET_NAME} PROPERTIES CXX_STANDARD_REQUIRED OFF)
set_target_properties(${TARGET_NAME} PROPERTIES LINKER_LANGUAGE C)
add_inih(${TARGET_NAME})

set(TARGET_NAME ${TARGET_NAME}_a)
add_library(${TARGET_NAME} STATIC)
add_library(${PROJECT_NAME}::${TARGET_NAME} ALIAS ${TARGET_NAME})
set_target_properties(${TARGET_NAME} PROPERTIES CXX_STANDARD_REQUIRED OFF)
set_target_properties(${TARGET_NAME} PROPERTIES LINKER_LANGUAGE C)
add_inih(${TARGET_NAME})

NewTargetSource()
AddSourceFolder(PUBLIC "${${PROJECT_NAME}_SOURCE_DIR}/cpp")

set(TARGET_NAME inihpp)
add_library(${TARGET_NAME} SHARED)
add_library(${PROJECT_NAME}::${TARGET_NAME} ALIAS ${TARGET_NAME})
target_compile_definitions(${TARGET_NAME} PUBLIC -DINI_SHARED_LIB)
target_compile_definitions(${TARGET_NAME} PRIVATE -DINI_SHARED_LIB_BUILDING)
target_link_libraries(${TARGET_NAME} PRIVATE ${PROJECT_NAME}::inih_a)
add_inih(${TARGET_NAME})

set(TARGET_NAME ${TARGET_NAME}_a)
add_library(${TARGET_NAME} STATIC)
add_library(${PROJECT_NAME}::${TARGET_NAME} ALIAS ${TARGET_NAME})
target_link_libraries(${TARGET_NAME} PRIVATE ${PROJECT_NAME}::inih_a)
add_inih(${TARGET_NAME})

ExportFromInstall(${PROJECT_NAME})